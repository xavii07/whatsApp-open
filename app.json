{
  "expo": {
    "name": "MensaLink",
    "slug": "mensalink",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mensalink",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#25D366"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xavii077.mensalink"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#25D366"
      },
      "package": "com.xavii077.mensalink"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "manifestQueries": {
              "package": [
                "com.whatsapp",
                "com.whatsapp.w4b",
                "org.telegram.messenger"
              ]
            }
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6339915348153686~9680636479"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "94e33654-d1fd-4fb6-8cf9-ff4b741bcdf9"
      },
      "router": {}
    },
    "owner": "prograwebs"
  }
}
